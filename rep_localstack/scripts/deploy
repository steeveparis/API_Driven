#!/usr/bin/env bash
set -e

export AWS_ACCESS_KEY_ID=test
export AWS_SECRET_ACCESS_KEY=test
export AWS_DEFAULT_REGION=us-east-1

AWS_ENDPOINT="${AWS_ENDPOINT:-https://super-duper-space-umbrella-9v75rggg64r2pqjx-4566.app.github.dev/}"
REGION="us-east-1"
FUNCTION_NAME="ec2-control"
ROLE_ARN="arn:aws:iam::000000000000:role/lambda-role"

echo "AWS_ENDPOINT=$AWS_ENDPOINT"

echo "[1/9] Création instance EC2 simulée"
INSTANCE_ID=$(aws --endpoint-url="$AWS_ENDPOINT" --region "$REGION" ec2 run-instances \
  --image-id ami-12345678 \
  --count 1 \
  --instance-type t2.micro \
  --query 'Instances[0].InstanceId' \
  --output text)

echo "INSTANCE_ID=$INSTANCE_ID"

echo "[2/9] Packaging Lambda"
cd lambda
zip -r ../lambda.zip ec2_control.py >/dev/null
cd ..

echo "[3/9] Suppression Lambda si elle existe déjà"
aws --endpoint-url="$AWS_ENDPOINT" --region "$REGION" lambda delete-function \
  --function-name "$FUNCTION_NAME" >/dev/null 2>&1 || true

echo "[4/9] Création fonction Lambda"
aws --endpoint-url="$AWS_ENDPOINT" --region "$REGION" lambda create-function \
  --function-name "$FUNCTION_NAME" \
  --runtime python3.11 \
  --role "$ROLE_ARN" \
  --handler ec2_control.lambda_handler \
  --zip-file fileb://lambda.zip \
  --environment "Variables={AWS_ENDPOINT=$AWS_ENDPOINT,INSTANCE_ID=$INSTANCE_ID}" \
  >/dev/null

echo "[5/9] Création API Gateway REST"
API_ID=$(aws --endpoint-url="$AWS_ENDPOINT" --region "$REGION" apigateway create-rest-api \
  --name ec2-api \
  --query 'id' \
  --output text)

echo "API_ID=$API_ID"

ROOT_ID=$(aws --endpoint-url="$AWS_ENDPOINT" --region "$REGION" apigateway get-resources \
  --rest-api-id "$API_ID" \
  --query 'items[0].id' \
  --output text)

echo "ROOT_ID=$ROOT_ID"

echo "[6/9] Création ressource /start"
START_RESOURCE_ID=$(aws --endpoint-url="$AWS_ENDPOINT" --region "$REGION" apigateway create-resource \
  --rest-api-id "$API_ID" \
  --parent-id "$ROOT_ID" \
  --path-part start \
  --query 'id' \
  --output text)

echo "START_RESOURCE_ID=$START_RESOURCE_ID"

echo "[7/9] Création ressource /stop"
STOP_RESOURCE_ID=$(aws --endpoint-url="$AWS_ENDPOINT" --region "$REGION" apigateway create-resource \
  --rest-api-id "$API_ID" \
  --parent-id "$ROOT_ID" \
  --path-part stop \
  --query 'id' \
  --output text)

echo "STOP_RESOURCE_ID=$STOP_RESOURCE_ID"

echo "[8/9] Configuration méthodes et intégrations"

# /start
aws --endpoint-url="$AWS_ENDPOINT" --region "$REGION" apigateway put-method \
  --rest-api-id "$API_ID" \
  --resource-id "$START_RESOURCE_ID" \
  --http-method POST \
  --authorization-type NONE >/dev/null

aws --endpoint-url="$AWS_ENDPOINT" --region "$REGION" apigateway put-integration \
  --rest-api-id "$API_ID" \
  --resource-id "$START_RESOURCE_ID" \
  --http-method POST \
  --type AWS_PROXY \
  --integration-http-method POST \
  --uri "arn:aws:apigateway:${REGION}:lambda:path/2015-03-31/functions/arn:aws:lambda:${REGION}:000000000000:function:${FUNCTION_NAME}/invocations" >/dev/null

# /stop
aws --endpoint-url="$AWS_ENDPOINT" --region "$REGION" apigateway put-method \
  --rest-api-id "$API_ID" \
  --resource-id "$STOP_RESOURCE_ID" \
  --http-method POST \
  --authorization-type NONE >/dev/null

aws --endpoint-url="$AWS_ENDPOINT" --region "$REGION" apigateway put-integration \
  --rest-api-id "$API_ID" \
  --resource-id "$STOP_RESOURCE_ID" \
  --http-method POST \
  --type AWS_PROXY \
  --integration-http-method POST \
  --uri "arn:aws:apigateway:${REGION}:lambda:path/2015-03-31/functions/arn:aws:lambda:${REGION}:000000000000:function:${FUNCTION_NAME}/invocations" >/dev/null

echo "[9/9] Déploiement API"
aws --endpoint-url="$AWS_ENDPOINT" --region "$REGION" apigateway create-deployment \
  --rest-api-id "$API_ID" \
  --stage-name dev >/dev/null

cat > .env.generated <<EOF
AWS_ENDPOINT=$AWS_ENDPOINT
INSTANCE_ID=$INSTANCE_ID
API_ID=$API_ID
START_URL=$AWS_ENDPOINT/restapis/$API_ID/dev/_user_request_/start
STOP_URL=$AWS_ENDPOINT/restapis/$API_ID/dev/_user_request_/stop
EOF

echo
echo "Déploiement terminé."
cat .env.generated
